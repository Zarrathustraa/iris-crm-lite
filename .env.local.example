# Copy this file to .env.local and fill in your values

# NextAuth
NEXTAUTH_SECRET=change-this-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# Google OAuth2 credentials (from Google Cloud Console)
# Required for both Sheets sync and Gmail sending
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Gmail sender address
GMAIL_FROM=your-email@gmail.com

# Google Sheets spreadsheet ID (pre-filled)
GOOGLE_SHEETS_ID=16Zl-hVeDwuyIzZetsdN1vyafcFZuNpvJjgNlEpTzuJU

# Database path (default: ./data/crm.db)
DB_PATH=./data/crm.db
